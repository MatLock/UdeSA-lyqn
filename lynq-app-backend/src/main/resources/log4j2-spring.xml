<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%style{%d{ISO8601}}{magenta} %highlight{%-5level} [%style{%t}{bright,blue}] %style{%c{1.}}{bright,yellow} [%style{%X{requestId}}{bright,green}]: %msg%n%throwable" />

        </Console>

        <Console name="JsonConsole" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%msg %n %throwable" />
        </Console>

        <RollingFile name="RollingFile"
                     fileName="./logs/lynq-backend-app.log"
                     filePattern="./logs/$${date:yyyy-MM}/lynq-backend-app-%d{-dd-MMMM-yyyy}-%i.log.gz">
            <PatternLayout>
                <pattern>%d %p %c{1.} [%t] %m%n</pattern>
            </PatternLayout>
            <Policies>
                <OnStartupTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="1000 MB" />
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
        </Root>
    </Loggers>
</Configuration>